{
  "all": true,
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": [
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.styles.ts",
    "src/**/index.ts",
    "src/main.tsx",
    "src/vite-env.d.ts",
    "src/setupTests.ts",
    "src/animations/**",
    "src/assets/**",
    "src/config/**",
    "src/constants/**",
    "src/styles/**",
    "src/theme/**",
    "src/types/**",
    "src/components/visualization/**",
    "dist/**",
    "coverage/**"
  ],
  "reporter": ["text", "html", "lcov"],
  "check-coverage": true,
  "lines": 80,
  "functions": 79,
  "branches": 64,
  "statements": 80,
  "report-dir": "./coverage"
}
